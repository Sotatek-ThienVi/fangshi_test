{
  "exportGuide": {
    "projectName": "Phong Thủy Vượng Khí",
    "version": "1.0.0",
    "exportDate": "2026-03-26",
    
    "structure": {
      "root": [
        "package.json",
        "vite.config.ts",
        "postcss.config.mjs",
        "EXPORT_GUIDE.md",
        "export-script.sh"
      ],
      
      "styles": {
        "path": "src/styles/",
        "files": [
          "theme.css",
          "fonts.css",
          "tailwind.css",
          "index.css"
        ]
      },
      
      "data": {
        "path": "src/app/data/",
        "files": [
          "mockData.ts"
        ]
      },
      
      "store": {
        "path": "src/app/store/",
        "files": [
          "cartStore.ts"
        ]
      },
      
      "components": {
        "path": "src/app/components/",
        "files": [
          "Layout.tsx",
          "ScrollToTop.tsx"
        ],
        "subfolders": {
          "ui": [
            "button.tsx",
            "badge.tsx",
            "input.tsx",
            "card.tsx",
            "tabs.tsx",
            "dropdown-menu.tsx",
            "sonner.tsx",
            "accordion.tsx",
            "utils.ts"
          ],
          "figma": [
            "ImageWithFallback.tsx"
          ]
        }
      },
      
      "pages": {
        "path": "src/app/pages/",
        "files": [
          "Home.tsx",
          "Products.tsx",
          "ProductDetail.tsx",
          "BlogList.tsx",
          "BlogDetail.tsx",
          "Cart.tsx",
          "Contact.tsx"
        ]
      },
      
      "routing": {
        "path": "src/app/",
        "files": [
          "routes.ts",
          "App.tsx"
        ]
      }
    },
    
    "dependencies": {
      "required": [
        "react@18.3.1",
        "react-dom@18.3.1",
        "react-router@7.13.0",
        "zustand@^5.0.12",
        "sonner@2.0.3",
        "lucide-react@0.487.0"
      ],
      "ui": [
        "@radix-ui/react-slot@1.1.2",
        "@radix-ui/react-dropdown-menu@2.1.6",
        "@radix-ui/react-tabs@1.1.3",
        "@radix-ui/react-accordion@1.2.3"
      ],
      "styling": [
        "class-variance-authority@0.7.1",
        "clsx@2.1.1",
        "tailwind-merge@3.2.0"
      ],
      "devDependencies": [
        "@tailwindcss/vite@4.1.12",
        "@vitejs/plugin-react@4.7.0",
        "tailwindcss@4.1.12",
        "vite@6.3.5"
      ]
    },
    
    "theme": {
      "colors": {
        "primary": "#D4AF37",
        "primaryDark": "#C4A030",
        "backgrounds": [
          "zinc-900",
          "gray-900",
          "black"
        ],
        "text": {
          "primary": "#FFFFFF",
          "secondary": "#F3F4F6",
          "accent": "#FEF3C7",
          "muted": "#D1D5DB"
        }
      },
      "borders": {
        "gold": "2px solid rgba(212, 175, 55, 0.4)"
      }
    },
    
    "buildCommands": {
      "install": "npm install",
      "dev": "npm run dev",
      "build": "npm run build",
      "preview": "npm run preview"
    },
    
    "deploymentOptions": [
      {
        "platform": "Vercel",
        "buildCommand": "npm run build",
        "outputDirectory": "dist",
        "framework": "vite"
      },
      {
        "platform": "Netlify",
        "buildCommand": "npm run build",
        "outputDirectory": "dist",
        "framework": "vite"
      },
      {
        "platform": "GitHub Pages",
        "buildCommand": "npm run build",
        "outputDirectory": "dist",
        "note": "Need to configure base path in vite.config.ts"
      }
    ],
    
    "importInstructions": {
      "figmaMake": {
        "step1": "Create new Figma Make project",
        "step2": "Install dependencies via AI prompt",
        "step3": "Copy files one by one in order: styles → data → components → pages → routing",
        "step4": "Test each phase before moving to next"
      },
      "localDevelopment": {
        "step1": "Create Vite project: npm create vite@latest",
        "step2": "Install dependencies from package.json",
        "step3": "Copy all source files maintaining folder structure",
        "step4": "Run npm install && npm run dev"
      },
      "existingProject": {
        "step1": "Check existing dependencies conflicts",
        "step2": "Merge package.json dependencies",
        "step3": "Copy files to appropriate locations",
        "step4": "Resolve import path conflicts",
        "step5": "Test thoroughly"
      }
    },
    
    "notes": [
      "Maintain exact folder structure",
      "Check import paths after copying",
      "Don't modify ImageWithFallback.tsx (protected file)",
      "CSS variables in theme.css are crucial for colors",
      "React Router v7 is required (not v6)",
      "Tailwind CSS v4 uses different config than v3"
    ]
  }
}
